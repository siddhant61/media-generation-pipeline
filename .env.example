# Media Generation Pipeline - Environment Variables
# Copy this file to .env and add your actual API keys

# OpenAI API Key (Required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Stability AI API Key (Required)
# Get your key from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your-stability-api-key-here

# Optional: Custom output directory
# OUTPUT_DIR=custom_output_directory

# Optional: LLM Configuration
# Scene generation model (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# Optional: TTS Configuration
# Text-to-speech model (default: tts-1)
# TTS_MODEL=tts-1
# TTS voice (options: alloy, echo, fable, onyx, nova, shimmer; default: alloy)
# TTS_VOICE=alloy

# Optional: Video Configuration
# Video FPS (default: 24)
# VIDEO_FPS=24

# Optional: Production Features
# Background music file path (MP3, WAV, etc.)
# BACKGROUND_MUSIC_FILE=/path/to/background_music.mp3
